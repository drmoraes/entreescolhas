# Variáveis de ambiente do projeto na Vercel (Settings → Environment Variables)
# Nunca commitar um arquivo .env real — este é só um modelo.

# Postgres (Supabase) — use a "Connection string" do modo Transaction Pooler
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:6543/postgres

# E-mail (Locaweb SMTP — continua sendo usado só como relay de envio)
SMTP_HOST=email-ssl.com.br
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=suporte@entreescolhas.com.br
SMTP_PASS=
SMTP_FROM_NAME=Entre Escolhas

# Mercado Pago (Checkout Pro)
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_REPORT_PRICE=7.97

# Regras de tentativa do teste
MAX_TEST_ATTEMPTS=3

# Admin
ADMIN_API_KEY=

# URL pública do site (sem barra no final)
APP_BASE_URL=https://www.entreescolhas.com.br
