# ═══════════════════════════════════════════════════════════════
# Entre Escolhas — Apache .htaccess para Locaweb
# ═══════════════════════════════════════════════════════════════

Options -Indexes

# ── HTTPS Redirect ──────────────────────────────────────────────
RewriteEngine On

# Força HTTPS (proxy-aware — evita loop atrás do SSL da Locaweb)
# Só redireciona se NEM o X-Forwarded-Proto NEM o HTTPS indicarem https.
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteCond %{HTTPS} !=on
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# Força www (só quando realmente não-www; roda depois do HTTPS já resolvido)
RewriteCond %{HTTP:X-Forwarded-Proto} =https [OR]
RewriteCond %{HTTPS} =on
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [R=301,L]

# ── Remover .html das URLs ──────────────────────────────────────
# Reescreve /banco-de-talentos → banco-de-talentos.html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# ── Segurança: bloquear acesso ao admin sem referrer ───────────
# (opcional — descomente se quiser restringir por IP)
# <Files "admin.html">
#   Require ip 177.0.0.0/8
# </Files>

# ── Cabeçalhos de segurança ─────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # HSTS (ativa após testar HTTPS funcionando)
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>

# ── Cache de ativos estáticos ───────────────────────────────────
# HTML sempre revalidado (o visitante vê a versão nova sem limpar cache)
<FilesMatch "\.(html)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, must-revalidate"
  </IfModule>
</FilesMatch>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html           "access plus 0 seconds"
  ExpiresByType text/css            "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/png           "access plus 6 months"
  ExpiresByType image/jpeg          "access plus 6 months"
  ExpiresByType image/webp          "access plus 6 months"
  ExpiresByType image/svg+xml       "access plus 6 months"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# ── Compressão Gzip ─────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# ── Página de erro personalizada ────────────────────────────────
ErrorDocument 404 /index.html
ErrorDocument 403 /index.html

# ── Bloquear arquivos sensíveis ─────────────────────────────────
<FilesMatch "\.(env|git|gitignore|log|sql|json)$">
  Require all denied
</FilesMatch>

# ── Charset padrão ──────────────────────────────────────────────
AddDefaultCharset UTF-8
